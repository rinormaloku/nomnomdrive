{
  "name": "nomnomdrive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @nomnomdrive/shared build && pnpm --filter @nomnomdrive/desktop build && pnpm --filter @nomnomdrive/cloud build",
    "build:cloud": "pnpm --filter @nomnomdrive/shared build && pnpm --filter @nomnomdrive/cloud build",
    "dev:desktop": "pnpm --filter @nomnomdrive/shared build && pnpm --filter @nomnomdrive/desktop dev",
    "dev:cloud": "pnpm --filter @nomnomdrive/shared build && pnpm --filter @nomnomdrive/cloud dev",
    "cli": "pnpm --filter @nomnomdrive/desktop cli",
    "nomnomdrive": "pnpm --filter @nomnomdrive/desktop cli",
    "lint": "eslint packages/*/src --ext .ts",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
