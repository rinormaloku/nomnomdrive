{
  "name": "@nomnomdrive/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI-powered document search and chat",
  "author": "NomNomDrive",
  "repository": "github:rinormaloku/nomnomdrive",
  "main": "dist/main/index.js",
  "bin": {
    "nomnomdrive": "dist/cli/index.js"
  },
  "scripts": {
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.json",
    "build": "pnpm build:renderer && pnpm build:main",
    "dev": "concurrently -k -n renderer,main,electron -c cyan,yellow,green \"vite dev\" \"tsc -p tsconfig.json --watch\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "cli": "electron dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && svelte-check --tsconfig tsconfig.renderer.json",
    "predist": "node -e \"const s='node_modules/@nomnomdrive/shared'; const fs=require('fs'); if(fs.lstatSync(s).isSymbolicLink()){const t=fs.realpathSync(s); fs.unlinkSync(s); fs.cpSync(t,s,{recursive:true}); console.log('Replaced workspace symlink with copy')}\"",
    "dist": "pnpm build && electron-builder --config electron-builder.config.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nomnomdrive/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "electron-updater": "^6.0.0",
    "fast-glob": "^3.3.0",
    "mammoth": "^1.8.0",
    "node-llama-cpp": "3.16.2",
    "officeparser": "^6.0.0",
    "pdf-parse": "^1.1.1",
    "picomatch": "^4.0.0",
    "sqlite-vec": "0.1.7-alpha.2",
    "word-extractor": "^1.0.4",
    "ws": "^8.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.0.0",
    "concurrently": "^9.2.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "svelte": "^5.53.6",
    "svelte-check": "^4.4.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
